# LakebaseOps Platform - Environment Variables
# Copy this file to .env and fill in your values
#
# Required variables are marked with [REQUIRED].
# Optional variables have sensible defaults shown after the "=".

# =============================================================================
# Databricks Workspace
# =============================================================================

# [REQUIRED] Databricks workspace hostname (without https://)
DATABRICKS_HOST=your-workspace.cloud.databricks.com

# Databricks personal access token (only needed for local development;
# in Databricks Apps the service principal token is injected automatically)
DATABRICKS_TOKEN=

# Service principal credentials (used by Databricks Apps runtime)
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# =============================================================================
# Unity Catalog
# =============================================================================

# Catalog and schema for operational Delta tables
OPS_CATALOG=ops_catalog
OPS_SCHEMA=lakebase_ops

# Schema for archived cold data
ARCHIVE_SCHEMA=lakebase_archive

# =============================================================================
# SQL Warehouse
# =============================================================================

# [REQUIRED] Databricks SQL Warehouse ID for DDL/DML execution
SQL_WAREHOUSE_ID=your-warehouse-id

# Optional display name (informational only)
SQL_WAREHOUSE_NAME=

# =============================================================================
# Lakebase Project
# =============================================================================

# [REQUIRED] Lakebase project UUID
LAKEBASE_PROJECT_ID=your-project-id

# [REQUIRED] Lakebase project display name
LAKEBASE_PROJECT_NAME=your-project-name

# [REQUIRED] Lakebase PostgreSQL endpoint hostname
LAKEBASE_ENDPOINT_HOST=your-endpoint.database.region.cloud.databricks.com

# Lakebase endpoint display name (used by lakebase_service.py)
LAKEBASE_ENDPOINT_NAME=

# PostgreSQL port (Lakebase always uses 5432)
LAKEBASE_ENDPOINT_PORT=5432

# Database name (Lakebase default is "databricks_postgres")
LAKEBASE_DB_NAME=databricks_postgres

# Default branch name
LAKEBASE_DEFAULT_BRANCH=production

# PostgreSQL version (16 or 17)
LAKEBASE_PG_VERSION=17

# =============================================================================
# Lakebase Authentication (for direct PG connections)
# =============================================================================

# OAuth token for Lakebase PG connections (auto-generated in production)
LAKEBASE_OAUTH_TOKEN=

# Database user (defaults to "databricks" service principal user)
LAKEBASE_DB_USER=databricks

# =============================================================================
# App Configuration
# =============================================================================

# CORS allowed origins (comma-separated). Set to your Databricks Apps domain.
# WARNING: Falls back to allow-all ("*") if unset — do NOT leave blank in prod.
CORS_ORIGINS=https://*.databricksapps.com

# Set to "1" or "true" to enable local development mode (mock data, relaxed auth)
LAKEBASE_LOCAL_DEV=

# =============================================================================
# Job IDs (populated after deploying jobs via create_all_jobs.py or DABs)
# =============================================================================

# JSON map of job name -> Databricks job ID
LAKEBASE_JOB_IDS={"metric_collector": 0, "index_analyzer": 0, "vacuum_scheduler": 0, "sync_validator": 0, "branch_manager": 0, "cold_archiver": 0, "cost_tracker": 0}
